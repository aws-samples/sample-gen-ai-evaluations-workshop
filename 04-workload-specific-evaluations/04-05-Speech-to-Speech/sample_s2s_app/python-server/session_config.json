{
  "session_transition": {
    "transition_threshold_seconds": 480,
    "audio_buffer_duration_seconds": 5,
    "enable_session_recording": false,
    "recording_output_dir": "./session_recordings",
    "max_single_message_bytes": 1024,
    "max_chat_history_bytes": 40960,
    "audio_start_timeout_seconds": 5.0,
    "next_session_ready_timeout_seconds": 30
  },
  "session_logging": {
    "log_transitions": true,
    "log_barge_in_events": true,
    "log_audio_events": true
  }
}
