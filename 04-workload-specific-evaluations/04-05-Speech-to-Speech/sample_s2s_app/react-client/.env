# Allow the dev server to be accessed through SageMaker Studio's proxy
# Without this, webpack's WebSocket connection for hot-reload will fail
WDS_SOCKET_HOST=0.0.0.0
WDS_SOCKET_PORT=0
DANGEROUSLY_DISABLE_HOST_CHECK=true

# WebSocket backend URL - update to SageMaker proxy URL when running in Studio
# e.g. wss://d-xxxx.studio.us-west-2.sagemaker.aws/jupyter/default/proxy/8081
REACT_APP_WEBSOCKET_URL=wss://localhost:8081
