# Copy this file to `.env` and fill in your values.
# The notebook loads this at the top of the AWS-config cell via python-dotenv.
# .env itself is gitignored — never commit real credentials.

# Region the Bedrock / SageMaker calls will use
AWS_REGION=us-east-1

# Option A: named profile from ~/.aws/config (recommended for local dev)
AWS_PROFILE=your-profile-name

# Option B: explicit temporary credentials (take precedence over AWS_PROFILE if set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
