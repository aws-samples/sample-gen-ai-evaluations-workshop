# Playwright E2E Test Environment Variables - Local Development
# This file is for local testing without authentication

# Frontend URL (localhost)
FRONTEND_URL=http://localhost:3000


# Test timeout settings (in milliseconds)
TEST_TIMEOUT=60000
NAVIGATION_TIMEOUT=30000
ACTION_TIMEOUT=15000

# WebSocket timeout
WEBSOCKET_TIMEOUT=10000

# Audio test settings
ENABLE_AUDIO_TESTS=true
AUDIO_TEST_DURATION=30000

# Screenshot and video settings
TAKE_SCREENSHOTS=true
RECORD_VIDEO=false

# Test data root (relative to project root)
TEST_DATA_ROOT=./test-data
