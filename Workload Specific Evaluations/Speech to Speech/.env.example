# AWS Configuration
# ==================

# AWS Region (default: us-east-1)
AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1

# AWS Profile (optional - if using named profiles from ~/.aws/credentials)
# AWS_PROFILE=your-profile-name

# AWS Credentials (optional - only if not using IAM roles or profiles)
# WARNING: Never commit actual credentials to version control
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=your-session-token

# CloudWatch Configuration
# ========================
LOG_GROUP_NAME=aws/spans
HOURS_BACK=24

# Evaluation Configuration
# ========================
DEFAULT_CONFIG_PATH=config/llm_judge_s2s_config.json
DEFAULT_VALIDATION_DATASET_PATH=data/s2s_validation_dataset.jsonl
DEFAULT_EVAL_DATASET_PATH=data/s2s_eval_data.jsonl
DEFAULT_REPORT_OUTPUT_PATH=test-evaluation-results/
DEFAULT_NUMBER_OF_EVAL_RUNS=1
